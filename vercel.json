{
  "buildCommand": "npm --prefix frontend/app run build:vercel",
  "outputDirectory": "frontend/app/dist",
  "installCommand": "npm --prefix frontend/app install",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://memory-game-team10-production.up.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
