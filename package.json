{
  "name": "squad-rps-team10",
  "private": true,
  "version": "0.2.0",
  "description": "Squad RPS - Team 10. One-shot launcher for backend + frontend.",
  "scripts": {
    "start": "node scripts/start.mjs",
    "dev:frontend": "npm --prefix frontend/app run dev -- --host 0.0.0.0",
    "dev:backend": "python -m uvicorn backend.python_api.app:app --host 0.0.0.0 --port 8000 --reload",
    "test:backend": "python -m unittest backend.python_api.tests.test_app",
    "test:frontend": "npm --prefix frontend/app run test",
    "e2e": "playwright test"
  }
}
