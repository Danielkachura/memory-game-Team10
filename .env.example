# ============================================================
# Squad RPS — Environment Variables
# No AI/LLM API is used in this project.
# ============================================================
# Copy this file to .env:
#   cp .env.example .env

# Backend port (default: 8000)
# PORT=8000

# Vite dev server proxies /api to this address
# VITE_BACKEND_URL=http://127.0.0.1:8000

# Production backend URL used by the Vercel frontend build
# VITE_BACKEND_URL=https://your-railway-backend.up.railway.app
